<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        <TextView
            android:id="@+id/tvSessionInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Session Info"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="4dp" />
        <TextView
            android:id="@+id/tvUsername"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="24dp" />
        <Button android:id="@+id/btnDailyEntry" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Daily Entry" android:layout_marginBottom="8dp" android:backgroundTint="#2E7D32" android:textColor="#FFFFFF" />
        <Button android:id="@+id/btnSellersList" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Sellers List" android:layout_marginBottom="8dp" android:backgroundTint="#1565C0" android:textColor="#FFFFFF" />
        <Button android:id="@+id/btnReports" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Reports" android:layout_marginBottom="8dp" android:backgroundTint="#6A1B9A" android:textColor="#FFFFFF" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnCashPaid" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:text="Cash Paid" android:layout_marginEnd="4dp" android:backgroundTint="#C62828" android:textColor="#FFFFFF" />
            <Button android:id="@+id/btnCashReceived" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                android:text="Cash Received" android:layout_marginStart="4dp" android:backgroundTint="#2E7D32" android:textColor="#FFFFFF" />
        </LinearLayout>
        <Button android:id="@+id/btnEditingCorrection" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Edit / Correct Entries" android:layout_marginTop="8dp" android:layout_marginBottom="8dp"
            android:backgroundTint="#EF6C00" android:textColor="#FFFFFF" />
        <Button android:id="@+id/btnBackupRestore" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Backup & Restore" android:layout_marginBottom="8dp" android:backgroundTint="#455A64" android:textColor="#FFFFFF" />
        <Button android:id="@+id/btnOldSellers" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Inactive Sellers" android:layout_marginBottom="8dp" android:backgroundTint="#6A1B9A" android:textColor="#FFFFFF" />
        <Button android:id="@+id/btnSettings" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Settings" android:backgroundTint="#555555" android:textColor="#FFFFFF" />
    </LinearLayout>
</ScrollView>