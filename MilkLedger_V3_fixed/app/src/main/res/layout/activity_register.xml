<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginBottom="24dp" />
        <EditText android:id="@+id/etUsername" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Username *" android:padding="16dp" android:background="@android:drawable/edit_text" />
        <EditText android:id="@+id/etPassword" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Password (min 4 chars) *" android:inputType="textPassword" android:layout_marginTop="12dp"
            android:padding="16dp" android:background="@android:drawable/edit_text" />
        <EditText android:id="@+id/etConfirmPassword" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Confirm Password *" android:inputType="textPassword" android:layout_marginTop="12dp"
            android:padding="16dp" android:background="@android:drawable/edit_text" />
        <EditText android:id="@+id/etSecurityQ" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Security Question * (e.g. Your pet name)" android:layout_marginTop="12dp"
            android:padding="16dp" android:background="@android:drawable/edit_text" />
        <EditText android:id="@+id/etSecurityA" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Security Answer *" android:layout_marginTop="12dp"
            android:padding="16dp" android:background="@android:drawable/edit_text" />
        <EditText android:id="@+id/etPin" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="PIN (optional, 4+ digits)" android:inputType="numberPassword" android:maxLength="6"
            android:layout_marginTop="12dp" android:padding="16dp" android:background="@android:drawable/edit_text" />
        <Button android:id="@+id/btnRegister" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Register" android:layout_marginTop="24dp" android:backgroundTint="#2E7D32" android:textColor="#FFFFFF" />
        <Button android:id="@+id/btnBackToLogin" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Back to Login" android:layout_marginTop="16dp" android:backgroundTint="#555555" />
    </LinearLayout>
</ScrollView>