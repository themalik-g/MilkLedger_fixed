<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">
    <EditText android:id="@+id/etAmount" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Amount" android:inputType="numberDecimal" android:padding="12dp" android:background="@android:drawable/edit_text" />
    <EditText android:id="@+id/etNotes" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Notes" android:layout_marginTop="8dp" android:padding="12dp" android:background="@android:drawable/edit_text" />
</LinearLayout>