<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">
    <EditText android:id="@+id/etLiters" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Liters" android:inputType="numberDecimal" android:padding="12dp" android:background="@android:drawable/edit_text" />
    <EditText android:id="@+id/etRate" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Rate" android:inputType="numberDecimal" android:layout_marginTop="8dp" android:padding="12dp"
        android:background="@android:drawable/edit_text" />
    <EditText android:id="@+id/etTime" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Time (morning/evening)" android:layout_marginTop="8dp" android:padding="12dp"
        android:background="@android:drawable/edit_text" />
</LinearLayout>