<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="#FFFFFF"
    android:elevation="2dp"
    android:gravity="center_vertical">
    <TextView android:id="@+id/tvInfo" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
        android:textSize="13sp" android:textColor="#333333" />
    <Button android:id="@+id/btnEdit" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Edit" android:textSize="10sp" android:backgroundTint="#1565C0" android:textColor="#FFFFFF" />
    <Button android:id="@+id/btnDelete" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Del" android:textSize="10sp" android:layout_marginStart="4dp" android:backgroundTint="#C62828" android:textColor="#FFFFFF" />
</LinearLayout>